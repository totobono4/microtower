pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- pico8 functions

function _init()
	palt(0,false)
	palt(15,true)
	load_level(0)
end

function _update()
	move()
end

function _draw()
 cls()
 
 draw_map()
 draw_blocs()
 draw_entities()
 draw_player()
 
 debug()
end

-->8
-- consts

b_ids={
	pipe=1,
	window=2
}

b_dat={
	[b_ids.pipe]={
		s={
			x=15*8,
			y=2*8,
			w=8,
			h=8,
		}
	},
	[b_ids.window]={
		s={
			x=15*8,
			y=3*8,
			w=8,
			h=8,
		}
	},
}

e_ids={}

e_dat={}

entities={
	{}
}

maps={
	void={
		cx=0,
		cy=0,
		sx=0,
		sy=0,
		cw=32,
		ch=16,
	}
}

buildings={
	default={
		[4]={1,2,2,1},
		[3]={2,1,1,2},
		[2]={2,1,1,2},
		[1]={1,2,2,1},
	}
}

players={
	default={
		s={
			x=1*8,
			y=0*8,
			w=8,
			h=8,
		},
		o={
			x=60,
			y=100,
		},
		x=0,
		y=0,
	}
}

lvls = {
	[1] = {
		p=players.default,
		m=maps.void,
		b=buildings.default,
		e={},
	}
}

tower={}
speed=2
-->8
-- base functions

function new_entity(e)
	return {
		id=e.id,
		s={
			x=e_dat[e.id].s.x,
			y=e_dat[e.id].s.y,
		},
		
		x=e.x,
		y=e.y,
	}
end

function load_level(n)
	local lvl={}
	for dat_e in all(lvls[n+1].e) do
		add(lvl, new_entity(dat_e))
	end

	print((lvls[n+1].p.s.w/2))

	tower={
		p={
			s=lvls[n+1].p.s,
			o=lvls[n+1].p.o,
			x=lvls[n+1].p.x,
			y=lvls[n+1].p.y,
		},
		m=lvls[n+1].m,
		b={unpack(lvls[n+1].b)},
		e=lvl,
	}
end

-->8
-- game functions

function move(mv)
	local mv = {
		x=0,
	}

	if btn(⬅️) then
		mv.x-=1
	end
	if btn(➡️) then
		mv.x+=1
	end

	tower.p.x+=mv.x*speed
	tower.p.x%=256
	tower.p.y+=1
end
-->8
-- draw functions

function draw_map()
	local p=tower.p
	local m=tower.m
	map(
		m.cx,m.cy,
		m.sx+p.x,m.sy,
		m.cw,m.ch
	)
	map(
		m.cx,m.cy,
		m.sx+p.x-m.cw*8,m.sy,
		m.cw,m.ch
	)
end

function draw_blocs()
	local p=tower.p
	for i=-3,14 do
		for j=-6,8 do
			local y=flr(p.y/8)+i
			local x=flr(p.x/8)+j
			
			local mody=(y+3)%#tower.b+1
			local modx=x%(#tower.b[mody])+1
			local b=b_dat[tower.b[mody][modx]]
			
			local xw=cos(j/32)*b.s.w
			local xpos=-sin(j/32)*4*b.s.w
			local ypos=p.y-y*b.s.h
			
			local dx=p.o.x+xpos
			local dy=p.o.y+ypos
		
			sspr(
	 		b.s.x,b.s.y,b.s.w,b.s.h,
	 		dx,dy,xw,b.s.h
	 	)
		end
	end
end

function draw_entities()
	for e in all(tower.e) do
 	sspr(
 		e.s.x,e.s.y,e.s.w,e.s.h,
 		e.x,e.y
 	)
 end
end

function draw_player()
	local p=tower.p

	sspr(
		p.s.x,p.s.y,p.s.w,p.s.h,
		p.o.x,p.o.y
	)
end

function debug()
	print("player pos "..tower.p.x.." "..tower.p.y, 7)
end

