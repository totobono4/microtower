__lua__
-- pico8 functions

function _init()
	load_level(0)
end

function _update()
	local mv = {
		x=0,
	}

	if btn(⬅️) then
		mv.x-=1
	end
	if btn(➡️) then
		mv.x+=1
	end
	
	move(mv)
end

function _draw()
 cls()
 
 for e in all(tower.e) do
 	sspr(e.s.x,e.s.y,8,8,e.x,0)
 end
end

