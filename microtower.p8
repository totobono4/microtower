p_ids={
 default=1,
	rocket=2,
	bullet=3,
	tri=4,
	plus=5,
	cross=6,
	star=7,
}

p_dat={
	[p_ids.default]=function(self)
	end,
	[p_ids.rocket]=function(self)
		self.y+=4
		
		local collided=false
		for e in all(tower.e) do
			if e==self then
				goto skiprocketcollide
			end
			if not e.killable then
				goto skiprocketcollide
			end
			if (
				self.xmin<e.xmax and
				self.xmax>e.xmin and
				self.ymin<e.ymax and
				self.ymax>e.ymin
				) or (
				self.xmin-128<e.xmax and
				self.xmax-128>e.xmin and
				self.ymin<e.ymax and
				self.ymax>e.ymin
				)
			then
				scoring(1)
				e.health-=1
				if e.health<=0 then
					scoring(10)
					spawn_particle(e.x,e.y,s_dat[s_ids.explosion],1)
					sfx(63)
					del(tower.e,e)
				end
				collided=true
			end
			::skiprocketcollide::
		end
		if collided then
			del(tower.e,self)
		end
	end,
	[p_ids.bullet]=function(self)
		local p=tower.p
		
		local y=cos(self.dir+self.rot)*speed.y/2
		local x=sin(self.dir+self.rot)/2
		if not self.attached and 
			y>-.2*speed.y and 
			y<.2*speed.y 
		then
			del(tower.e,self)
		end
		
		self.y+=y
		self.x+=x
	end,
	[p_ids.tri]=function(self)		
		if game_time-self.b_last>=self.b_cd then
			self.b_last=game_time
			spawn_bullet(self,.25,.20,s_dat[s_ids.bullet_b])
			spawn_bullet(self,.27,.20,s_dat[s_ids.bullet])
			spawn_bullet(self,.29,.20,s_dat[s_ids.bullet_p])
			spawn_bullet(self,.75,.20,s_dat[s_ids.bullet_b])
			spawn_bullet(self,.77,.20,s_dat[s_ids.bullet])
			spawn_bullet(self,.79,.20,s_dat[s_ids.bullet_p])
		end
	end,
	[p_ids.plus]=function(self)		
		if game_time-self.b_last>=self.b_cd then
			self.b_last=game_time
			spawn_bullet(self,0,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.25,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.5,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.75,0,s_dat[s_ids.bullet_o])
		end
	end,
	[p_ids.cross]=function(self)		
		if game_time-self.b_last>=self.b_cd then
			self.b_last=game_time
			spawn_bullet(self,.125,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.375,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.625,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.875,0,s_dat[s_ids.bullet_o])
		end
	end,
	[p_ids.star]=function(self)		
		if game_time-self.b_last>=self.b_cd then
			self.b_last=game_time
			spawn_bullet(self,0,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.25,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.5,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.75,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.125,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.375,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.625,0,s_dat[s_ids.bullet_o])
			spawn_bullet(self,.875,0,s_dat[s_ids.bullet_o])
			p_dat[p_ids.cross](self)
		end
	end,
}

