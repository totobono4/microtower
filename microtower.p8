pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- pico8 functions

function _init()
	palt(0,false)
	palt(15,true)
	music()
end

function _update()
	if not game_launched then
		if btn(❎) then
			launch_game()
		end
		goto skipupdate
	end

	game_time = time()

	update_inputs()
	update_events()
	update_entities()
	update_particles()
	
	if hit() then
		register_highscore(score,0)
		back_to_menu()
	end
	
	::skipupdate::
end

function _draw()
	cls()
	if not game_launched then
		draw_menu()
		goto skipdraw
	end
 
 draw_map()
 draw_blocs()
 draw_particles()
 draw_player()
 draw_entities()
 
 debug()
 
 ::skipdraw::
end

function debug()
end

