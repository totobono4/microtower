-->8
-- base functions

function new_entity(e)
	return {
		id=e.id,
		s={
			x=e_dat[e.id].s.x,
			y=e_dat[e.id].s.y,
		},
		
		x=e.x,
	}
end

function load_level(n)
	local lvl={}
	for dat_e in all(lvls[n+1].e) do
		add(lvl, new_entity(dat_e))
	end

	tower={
		m=lvls[n+1].m,
		b={unpack(lvls[n+1].b)},
		e=lvl,
	}
end
-->8
-- game functions

function move(mv)
	for e in all(tower.e) do
		if e.id == e_ids.player then
			e.x+=mv.x
		end
	end
end
